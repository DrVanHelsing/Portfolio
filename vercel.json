{
  "installCommand": "cd portfolio.client && npm install --legacy-peer-deps",
  "buildCommand": "cd portfolio.client && npm run build",
  "outputDirectory": "portfolio.client/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
